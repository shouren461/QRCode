<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/bg_history_header">

    <TextView
        android:id="@+id/tv_history_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="36dp"
        android:text="@string/history_page_title"
        android:textSize="22sp"
        android:textColor="@color/black_text"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />


    <ImageView
        android:id="@+id/iv_history_back"
        android:layout_marginStart="20dp"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:paddingEnd="2dp"
        android:src="@mipmap/ic_results_page_return"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@+id/tv_history_title"
        app:layout_constraintBottom_toBottomOf="@+id/tv_history_title"
        app:layout_constraintStart_toStartOf="parent"
        />

    <TextView
        android:id="@+id/tv_history_header_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="@string/history_page_favorites"
        android:textColor="@color/black_text"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@+id/tv_history_title"
        app:layout_constraintBottom_toBottomOf="@+id/tv_history_title"
        app:layout_constraintStart_toEndOf="@+id/iv_history_back"
        />
    <ImageView
        android:id="@+id/iv_history_filter"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:padding="3dp"
        android:src="@drawable/ic_history_selector"
        app:layout_constraintTop_toTopOf="@+id/tv_history_title"
        app:layout_constraintBottom_toBottomOf="@+id/tv_history_title"
        app:layout_constraintEnd_toStartOf="@+id/iv_history_delete"
        />
    <ImageView
        android:id="@+id/iv_history_select_all"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:padding="3dp"
        android:src="@mipmap/ic_history_checkbox_unselected"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@+id/tv_history_title"
        app:layout_constraintBottom_toBottomOf="@+id/tv_history_title"
        app:layout_constraintEnd_toStartOf="@+id/iv_history_delete" />

    <ImageView
        android:id="@+id/iv_history_delete"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="20dp"
        android:padding="3dp"
        android:src="@drawable/ic_history_button_delete"
        app:layout_constraintTop_toTopOf="@+id/tv_history_title"
        app:layout_constraintBottom_toBottomOf="@+id/tv_history_title"
        app:layout_constraintEnd_toEndOf="parent"
        />
    <!--滚动视图-->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_history"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:paddingStart="20dp"
        android:paddingBottom="16dp"
        android:paddingEnd="20dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_history_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />



</androidx.constraintlayout.widget.ConstraintLayout>