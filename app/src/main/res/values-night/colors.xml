<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 基础颜色 - 深色模式适配 -->
    <!-- 将纯白背景映射为深色背景，符合 Material Design 深色主题规范 -->
    <color name="colorPrimary">#121212</color>         <!-- 主背景色（极深灰） -->
    <color name="colorPrimaryDark">#0A0A0A</color>    <!-- 状态栏/顶部导航深色 -->
    <color name="colorAccent">#4991FF</color>         <!-- 品牌强调色保持不变 -->
    <color name="ripple">#33FFFFFF</color>            <!-- 深色背景上的水波纹反馈（半透明白） -->
    <color name="transparent">#00000000</color>

    <!-- 语义化颜色（浅色模式下为白/黑，深色模式下语义反转） -->
    <color name="white">#1E1E1E</color>                <!-- 原纯白背景 -> 深色表面 -->
    <color name="black">#FFFFFF</color>               <!-- 原深灰文字 -> 浅灰白文字（确保可读性） -->
    <color name="grey">#121212</color>                <!-- 原亮灰色 -> 深灰色（用于深色模式的灰底） -->
    <color name="scan_frame">#404040</color>          <!-- 原扫描框灰色 -> 适配深色背景 -->
    <color name="black_text">#FFFFFF</color>

    <!-- ViewLib 组件专用颜色 - 深色模式 -->
    <!-- 对话框 -->
    <color name="dialog_bg">#1E1E1E</color>           <!-- 弹窗背景（比主背景稍亮，体现卡片层次） -->
    <color name="dialog_text_first">#FFFFFF</color>   <!-- 一级标题：纯白 -->
    <color name="dialog_text_second">#B0BEC5</color>  <!-- 二级正文：柔和的灰蓝色 -->

    <!-- 按钮 -->
    <color name="button_enable">#FFC107</color>       <!-- 按钮可用（琥珀色强调，保持不变） -->
    <color name="button_disable">#804991FF</color>    <!-- 按钮不可用（保持半透明蓝，深色背景下依然可见） -->

    <!-- 底部导航栏 -->
    <color name="bottom_tab_selected_color">#80B5FF</color>  <!-- 选中态（保持品牌琥珀色） -->
    <color name="bottom_tab_unselected_color">#6A7B8C</color><!-- 未选中态（比浅色模式调亮，避免在深色背景下看不清） -->

    <!-- 边框和分割线 -->
    <color name="shouren_border">#374151</color>      <!-- 深色模式下的边框 -->
    <color name="shouren_divider">#374151</color>     <!-- 深色模式下的分割线 -->

</resources>